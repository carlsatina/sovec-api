DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/solvec"
PORT=4000
JWT_SECRET="replace-with-a-secure-random-secret"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# SMS provider settings
# Use mock for local development, semaphore for real delivery.
SMS_PROVIDER="mock"
SEMAPHORE_API_KEY=""
SEMAPHORE_SENDER_NAME=""
SEMAPHORE_OTP_MESSAGE="Your E-Ride OTP is {otp}. It expires in 5 minutes."

# Email provider settings
# Use stub for local development, resend for real delivery.
EMAIL_PROVIDER="stub"
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Safety escalation channels (optional)
SAFETY_ESCALATION_PHONES=""
SAFETY_ESCALATION_EMAILS=""
SAFETY_ESCALATION_WEBHOOK_URL=""
SAFETY_DELIVERY_MAX_ATTEMPTS="3"
SAFETY_DELIVERY_RETRY_DELAY_MS="250"

# Admin bootstrap hardening
ADMIN_BOOTSTRAP_SECRET=""
# For local-only bootstrap without secret (not recommended outside dev)
ALLOW_INSECURE_ADMIN_BOOTSTRAP="false"
# Allow additional admin promotions after at least one admin exists
ALLOW_ADMIN_BOOTSTRAP_WHEN_ADMIN_EXISTS="false"
